DEPLOYMENT_NAME=fixture-tls-acme-real-execute-attempt
BASE_DOMAIN=github.example.com
DOMAIN_MODE=flat-siblings
PLATFORM=plain-nginx
TLS_MODE=acme-http01
TLS_CERT=
TLS_KEY=
INPUT_MODE=advanced
INSTALL_INPUT_MODE=advanced
ERROR_ROOT=/tmp/errors
LOG_DIR=/tmp/logs
OUTPUT_DIR=./dist/fixture-tls-acme-real-execute-attempt
NGINX_SNIPPETS_TARGET_HINT=/tmp/snippets
NGINX_VHOST_TARGET_HINT=/tmp/conf.d
RUN_APPLY_DRY_RUN=0
EXECUTE_APPLY=0
BACKUP_DIR=
RUN_NGINX_TEST_AFTER_EXECUTE=0
NGINX_TEST_CMD=nginx\ -t
ASSUME_YES=1
DEFAULT_ERROR_ROOT=/tmp/errors
DEFAULT_LOG_DIR=/tmp/logs
DEFAULT_OUTPUT_DIR=./dist/fixture-tls-acme-real-execute-attempt
DEFAULT_NGINX_SNIPPETS_TARGET_HINT=/tmp/snippets
DEFAULT_NGINX_VHOST_TARGET_HINT=/tmp/conf.d
